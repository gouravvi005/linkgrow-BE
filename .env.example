# App Config
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/linkgrow?schema=public"
PRISMA_CLIENT_ENGINE_TYPE="library"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Better Auth
BETTER_AUTH_SECRET="super-secret-better-auth-key-32-chars-long"
BETTER_AUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_mock_api_key_for_development"
EMAIL_FROM="noreply@linkgrow.com"

# Storage (Cloudflare R2)
CLOUDFLARE_R2_ACCESS_KEY_ID="mock_r2_access_key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="mock_r2_secret_key"
CLOUDFLARE_R2_BUCKET_NAME="linkgrow-media-dev"
CLOUDFLARE_R2_ENDPOINT="https://mock-account-id.r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL="http://localhost:3000/static"

# Payments
STRIPE_SECRET_KEY="sk_test_mock_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_mock_webhook_secret"
RAZORPAY_KEY_ID="rzp_test_mock_key"
RAZORPAY_KEY_SECRET="rzp_mock_secret"
RAZORPAY_WEBHOOK_SECRET="rzp_mock_webhook_secret"

# WhatsApp Meta API (Optional)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
